{
  "name": "medsafe-backend",
  "version": "1.0.0",
  "description": "Medsafe Backend API - Gerenciamento de medicamentos",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "prisma db push --accept-data-loss && node dist/server.js",
    "dev": "tsx --env-file=.env watch src/server.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^10.0.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.8.5",
    "fastify-plugin": "^4.5.1",
    "nodemailer": "^8.0.7",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
